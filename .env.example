# ─────────────────────────────────────────────────────────────────────────────
# 3CX Flow Explainer — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of server names (use any short identifiers you like).
THREECX_SERVERS=pbx1,pbx2

# ── Server 1 ──────────────────────────────────────────────────────────────────
THREECX_PBX1_BASE_URL=https://pbx1.example.com
THREECX_PBX1_CLIENT_ID=your-client-id-here
THREECX_PBX1_CLIENT_SECRET=your-client-secret-here

# ── Server 2 ──────────────────────────────────────────────────────────────────
THREECX_PBX2_BASE_URL=https://pbx2.example.com
THREECX_PBX2_CLIENT_ID=your-client-id-here
THREECX_PBX2_CLIENT_SECRET=your-client-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# SINGLE-SERVER LEGACY FORMAT (fallback when THREECX_SERVERS is not set):
# ─────────────────────────────────────────────────────────────────────────────
# THREECX_BASE_URL=https://pbx.example.com
# THREECX_CLIENT_ID=your-client-id-here
# THREECX_CLIENT_SECRET=your-client-secret-here
